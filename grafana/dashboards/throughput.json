{
  "title": "Throughput",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests per Second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total[5m]))",
          "legendFormat": "inference requests/sec"
        },
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "api requests/sec"
        }
      ]
    }
  ]
}
